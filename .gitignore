# AssemblyZero-specific gitignore
# Note: Parent Projects/.gitignore covers common patterns

# Claude Code local settings (machine-specific, prevent merge overwrites)
.claude/settings.local.json

# Claude Code checkpoint (ephemeral, session-scoped)
.claude/checkpoint.json

# Claude Code temporary files
tmpclaude-*

# #1134: cascade detector runtime log -- now writes to
# ~/.claude/assemblyzero/cascade-events.jsonl (absolute, outside any repo
# tree). Defense in depth: also ignore the legacy relative path so
# nothing accidentally reintroduces it as a tracked artifact.
tmp/cascade-events.jsonl

# #1151: operational log/state writers were relocated to absolute paths
# under ~/.claude/assemblyzero/. Their legacy tracked locations are
# .gitignore'd as defense in depth (so any caller that ignored the
# relocation can't reintroduce dirty-worktree breakage). See audit
# tools/audit_tracked_log_writers.py.
data/hourglass/history.json
data/hourglass/age_meter.json
docs/lineage/workflow-audit.jsonl
docs/lld/lld-status.json

# #1151: audit script output (TSV at repo root)
audit_tracked_log_writers_results.tsv

# #1196: audit script outputs (TSV at repo root) — regenerable
audit_fleet_auto_merge_readiness_results.tsv
audit_fleet_branch_protection_results.tsv

# #1196: pickup-decide hot state (10K+ lines, regenerable per session)
data/.pickup-surface.json

# Generated files
*.generated.json

# Gemini retry logs (generated at runtime)
# Keep the directory structure but ignore log files
logs/*.log

# Batch workflow logs (generated by tools/batch-workflow.sh)
logs/batch/

# Session shards (ephemeral, consolidated on commit)
# Issue #57: Distributed Session-Sharded Logging
logs/active/
!logs/active/.gitkeep

# Environment secrets
.env

# Python cache
__pycache__/
*.pyc

# Coverage artifacts
.coverage
.coverage.*

# Implementation status artifacts (generated by workflow tools)
.implement-status-*.json

# #1706/#1712: the GEMINI.md.bak* backup family was accidentally/manually
# tracked (GEMINI.md.bak swept in 2026-03-18 #778; GEMINI.md.bak001.md saved as
# a "user backup"), confused 20+ sessions ("unclear if debris"), and spawned
# recurring stashes (sessions kept deleting them then stashing the deletion
# instead of committing). The rename-workaround that created .bak files is
# retired (agy migration, ADR-0220). Glob-guard the whole family.
GEMINI.md.bak*

# Harvest artifacts (generated reports)
harvest-*.json
harvest-*.xlsx

# Janitor reports (generated by tools/run_janitor_workflow.py, Issue #94)
janitor-reports/

# Blog drafts (not ready for public)
docs/blog/

# Local AssemblyZero state (Issue #78)
# RAG vector store (Issue #88) - regenerated via tools/rebuild_knowledge_base.py
.assemblyzero/
!.assemblyzero/config.example.json

# Keep databases ignored (redundant but explicit)
*.db
*.sqlite

# Session transcripts (auto-generated, untracked)
data/unleashed/
data/handoff-log.md
transcripts/

# Hourglass Protocol local state (Issue #535 — age meter is per-developer)
data/hourglass/age_meter.json

# Deferred-scope audit caches — regenerable via tools/audit_deferred_scope.py (#930, #1049)
data/closed-issues-snapshot-*.json
data/issue-state-index-*.json
data/deferred-scope-llm-cache.json
# Session logs — internal-only; never publish (added 2026-05-23 after exposure discovery, see #1216)
docs/session-logs/
docs/dom-dumps/
